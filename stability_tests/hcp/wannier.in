include totalE.in

wannier \
	innerWindow -0.6 0.5 \
	outerWindow -0.6 3.5 \
	saveMomenta no \
	loadRotations yes \ 
	localizationMeasure FiniteDifference \
	saveWfnsRealSpace no


wannier-initial-state totalE.$VAR
wannier-dump-name wannier.$VAR
wannier-minimize nIterations 100

