include totalE.in

wannier \
	innerWindow -0.9187325900174191 0.22 \
	outerWindow -0.9187325900174191 2.0 \
	loadRotations yes \
	localizationMeasure FiniteDifference \ 
	saveMomenta yes \
	saveWfnsRealSpace yes

wannier-initial-state totalE.$VAR
wannier-dump-name wannier.$VAR
wannier-minimize \
	nIterations 1 \
	energyDiffThreshold 1e-8

wannier-center-pinned C 1 s
wannier-center-pinned C 2 s
wannier-center-pinned C 1 px
wannier-center-pinned C 2 px
wannier-center-pinned C 1 py
wannier-center-pinned C 2 py
wannier-center-pinned C 1 pz 
wannier-center-pinned C 2 pz 

