include totalE.in

wannier \
	innerWindow -0.9187325900174191 0.3 \
	outerWindow -0.9187325900174191 1.4 \
	loadRotations no \
	localizationMeasure FiniteDifference \
	saveMomenta yes \
	saveWfns no

wannier-initial-state totalE.$VAR
wannier-dump-name wannier.$VAR
wannier-minimize \
	nIterations 100 \
	energyDiffThreshold 1e-8 \
	dirUpdateScheme L-BFGS

wannier-center B 1 s
wannier-center B 1 px
wannier-center B 1 py
wannier-center B 1 pz
wannier-center N 1 s
wannier-center N 1 px
wannier-center N 1 py
wannier-center N 1 pz


